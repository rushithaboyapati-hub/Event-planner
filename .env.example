# Copy this file to .env and adjust values for your local setup

# PostgreSQL (local by default)
DB_HOST=localhost
DB_NAME=eventplanner
DB_USER=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=replace-with-a-long-secure-secret
JWT_EXPIRATION_MS=86400000

# MongoDB (local by default)
MONGODB_URI=mongodb://127.0.0.1:27017/eventplanner

# Ports
SPRINGBOOT_PORT=8090
NODEJS_PORT=3001
FASTAPI_PORT=8000
FRONTEND_PORT=5173
